<div class="container">
  <h1 class="my-4">Pets</h1>
  <table class="table table-hover table-bordered">
    <thead class="table-dark">
      <tr>
        <th>Name</th>
        <th>Species</th>
        <th>Breed</th>
        <th>Owner Name</th>
        <th>Date of Birth</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @pets.each do |pet| %>
        <tr>
          <td><%= pet.name %></td>
          <td><%= pet.species %></td>
          <td><%= pet.breed %></td>
          <td><%= "#{pet.owner.first_name} #{pet.owner.last_name}" %></td>
          <td><%= pet.date_of_birth.strftime("%B %d, %Y") %></td>
          <td>
            <%= link_to "View Details", pet_path(pet), class: "btn btn-sm btn-outline-info" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div> 